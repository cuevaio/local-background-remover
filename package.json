{
  "name": "background-removal-monorepo",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/web",
    "apps/desktop",
    "apps/rmbg"
  ],
  "devDependencies": {
    "turbo": "^2.8.21"
  },
  "scripts": {
    "dev": "turbo run dev --filter=desktop",
    "dev:web": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "turbo run check",
    "py:sync": "turbo run py:sync --filter=rmbg",
    "py:lock": "turbo run py:lock --filter=rmbg"
  }
}
