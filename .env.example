POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=

POLAR_PRODUCT_APP_ID=
POLAR_PRODUCT_CLI_ID=
POLAR_PRODUCT_BOTH_ID=

POLAR_BENEFIT_CLI_ID=
POLAR_BENEFIT_DESKTOP_ID=

# Base64-encoded Ed25519 private key bytes (32 bytes)
LICENSE_SIGNING_PRIVATE_KEY=

# Public key used by CLI/Desktop to verify offline license tokens
RMBG_LICENSE_PUBLIC_KEY=
RMBG_LICENSE_API_BASE_URL=https://local.backgroundrm.com
# Optional path to a PEM CA bundle used by CLI/Desktop license API calls.
RMBG_LICENSE_CA_BUNDLE=
RMBG_WORKER_IDLE_SECONDS=300

# Optional override for install metadata endpoint.
# If unset, /api/releases/latest resolves from GitHub latest release discovery.
RMBG_LATEST_VERSION=

# Optional GitHub token used by /api/releases/latest.
# Recommended for private repositories to resolve latest release automatically,
# and required for /releases/<tag>/... download proxy routes.
RMBG_GITHUB_TOKEN=

# Vercel Flags SDK key bundle injected by Vercel (use `vercel env pull`).
FLAGS=

# Optional for Flags Explorer encrypted overrides / encrypted flag values.
FLAGS_SECRET=
